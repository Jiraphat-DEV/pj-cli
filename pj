#!/bin/zsh
# pj - Multi-Project Git Manager
# A CLI tool for tech leads managing multiple git repositories

set -o pipefail

readonly PJ_VERSION="1.0.0"
readonly PJ_CONFIG="${PJ_CONFIG:-$HOME/.pjconfig}"

# ── Colors (disabled when piped) ──────────────────────────────────────────────

if [[ -t 1 ]] && [[ "${TERM:-dumb}" != "dumb" ]]; then
    C_RESET=$'\e[0m'
    C_BOLD=$'\e[1m'
    C_DIM=$'\e[2m'
    C_RED=$'\e[31m'
    C_GREEN=$'\e[32m'
    C_YELLOW=$'\e[33m'
    C_BLUE=$'\e[34m'
    C_CYAN=$'\e[36m'
    C_BOLD_RED=$'\e[1;31m'
    C_BOLD_GREEN=$'\e[1;32m'
    C_BOLD_YELLOW=$'\e[1;33m'
    C_BOLD_CYAN=$'\e[1;36m'
    C_BOLD_WHITE=$'\e[1;37m'
else
    C_RESET='' C_BOLD='' C_DIM='' C_RED='' C_GREEN='' C_YELLOW=''
    C_BLUE='' C_CYAN='' C_BOLD_RED='' C_BOLD_GREEN='' C_BOLD_YELLOW=''
    C_BOLD_CYAN='' C_BOLD_WHITE=''
fi

# ── Config Parser ─────────────────────────────────────────────────────────────

typeset -a REPO_PATHS REPO_NAMES REPO_GROUPS
typeset -A REPO_BY_NAME

load_config() {
    if [[ ! -f "$PJ_CONFIG" ]]; then
        echo "${C_RED}No config found at $PJ_CONFIG${C_RESET}"
        echo "Run '${C_CYAN}pj init${C_RESET}' to create one, or '${C_CYAN}pj add <path> <group>${C_RESET}' to start manually."
        return 1
    fi

    REPO_PATHS=() REPO_NAMES=() REPO_GROUPS=()
    REPO_BY_NAME=()

    while IFS= read -r line; do
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ -z "${line// /}" ]] && continue

        local path_part="${line%%=*}"
        local group_part="${line#*=}"

        # Trim whitespace
        path_part="${path_part## }" ; path_part="${path_part%% }"
        group_part="${group_part## }" ; group_part="${group_part%% }"

        [[ -z "$path_part" ]] && continue

        local name="$(basename "$path_part")"
        REPO_PATHS+=("$path_part")
        REPO_NAMES+=("$name")
        REPO_GROUPS+=("$group_part")
        REPO_BY_NAME[$name]=${#REPO_PATHS[@]}
    done < "$PJ_CONFIG"
}

# ── Helpers ───────────────────────────────────────────────────────────────────

print_separator() {
    printf " ${C_DIM}%s${C_RESET}\n" "$(printf '─%.0s' {1..78})"
}

get_default_branch() {
    local repo_path="$1"

    # 1. Check origin HEAD (set by remote)
    local ref
    ref=$(git -C "$repo_path" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null)
    if [[ -n "$ref" ]]; then
        echo "${ref##*/}"
        return
    fi

    # 2. Check local branches
    if git -C "$repo_path" show-ref --verify --quiet refs/heads/main 2>/dev/null; then
        echo "main" ; return
    fi
    if git -C "$repo_path" show-ref --verify --quiet refs/heads/master 2>/dev/null; then
        echo "master" ; return
    fi

    # 3. Fallback: current branch
    git -C "$repo_path" branch --show-current 2>/dev/null
}

get_filtered_indices() {
    local filter_group="$1"
    local indices=()

    for i in {1..${#REPO_PATHS[@]}}; do
        if [[ -z "$filter_group" ]] || [[ "${REPO_GROUPS[$i]}" == "$filter_group" ]]; then
            indices+=($i)
        fi
    done
    echo "${indices[@]}"
}

get_unique_groups() {
    local -a groups=()
    local -A seen=()
    for g in "${REPO_GROUPS[@]}"; do
        if [[ -z "${seen[$g]}" ]]; then
            groups+=("$g")
            seen[$g]=1
        fi
    done
    echo "${groups[@]}"
}

# ── pj help ───────────────────────────────────────────────────────────────────

cmd_help() {
    cat <<EOF
${C_BOLD_CYAN}pj${C_RESET} - Multi-Project Git Manager v${PJ_VERSION}

${C_BOLD}USAGE${C_RESET}
    pj <command> [options]

${C_BOLD}COMMANDS${C_RESET}
    ${C_CYAN}sync${C_RESET} [group] [-p]      Switch to default branch & pull latest
    ${C_CYAN}status${C_RESET} [group]          Dashboard of all repos (branch, status, ahead/behind)
    ${C_CYAN}branches${C_RESET} [repo]         Show branches across repos
    ${C_CYAN}cleanup${C_RESET} [group]         Delete merged branches (with confirmation)
    ${C_CYAN}list${C_RESET} [--paths|--groups] List managed repos and groups
    ${C_CYAN}add${C_RESET} <path> [group]      Add a repo to config
    ${C_CYAN}remove${C_RESET} <path|name>      Remove a repo from config
    ${C_CYAN}init${C_RESET} [--root path]      Auto-discover repos and generate config

${C_BOLD}OPTIONS${C_RESET}
    -p, --parallel    Run git operations in parallel (sync)
    --dry-run         Preview without executing (cleanup)
    --force           Skip confirmation prompts (cleanup)
    --local           Show only local branches (branches)
    --remote          Show only remote branches (branches)
    --paths           Show full paths (list)
    --groups          Show only group names (list)

${C_BOLD}EXAMPLES${C_RESET}
    pj sync                   Sync all repos to default branch
    pj sync fitsloth-crm      Sync only CRM repos
    pj sync -p                Sync all repos in parallel
    pj status                 Show status dashboard
    pj branches fitsloth-crm  Show branches for CRM repos
    pj cleanup --dry-run      Preview merged branches to delete
EOF
}

# ── pj list ───────────────────────────────────────────────────────────────────

cmd_list() {
    load_config || return 1

    local show_paths=false show_groups_only=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --paths) show_paths=true ;;
            --groups) show_groups_only=true ;;
        esac
        shift
    done

    if $show_groups_only; then
        local groups=(${(s: :)$(get_unique_groups)})
        for g in "${groups[@]}"; do
            echo "$g"
        done
        return
    fi

    local groups=(${(s: :)$(get_unique_groups)})
    local total=0

    local count=0 rdir=""
    echo ""
    for group in "${groups[@]}"; do
        count=0
        for i in {1..${#REPO_PATHS[@]}}; do
            [[ "${REPO_GROUPS[$i]}" == "$group" ]] && ((count++))
        done

        printf " ${C_BOLD_WHITE}%s${C_RESET} ${C_DIM}(%d repos)${C_RESET}\n" "$group" "$count"

        for i in {1..${#REPO_PATHS[@]}}; do
            if [[ "${REPO_GROUPS[$i]}" == "$group" ]]; then
                if $show_paths; then
                    printf "   ${C_CYAN}%-25s${C_RESET} %s\n" "${REPO_NAMES[$i]}" "${REPO_PATHS[$i]}"
                else
                    local rdir="${REPO_PATHS[$i]}"
                    if [[ -d "$rdir/.git" ]]; then
                        printf "   ${C_CYAN}%s${C_RESET}\n" "${REPO_NAMES[$i]}"
                    else
                        printf "   ${C_RED}%s [MISSING]${C_RESET}\n" "${REPO_NAMES[$i]}"
                    fi
                fi
                ((total++))
            fi
        done
        echo ""
    done

    printf " ${C_DIM}Total: %d repos in %d groups${C_RESET}\n\n" "$total" "${#groups[@]}"
}

# ── pj add ────────────────────────────────────────────────────────────────────

cmd_add() {
    local rdir="$1"
    local group="${2:-ungrouped}"

    if [[ -z "$rdir" ]]; then
        echo "${C_RED}Usage: pj add <path> [group]${C_RESET}"
        return 1
    fi

    # Resolve to absolute path
    if [[ "$rdir" == "~"* ]]; then
        rdir="${rdir/#\~/$HOME}"
    fi
    if [[ "$rdir" != /* ]]; then
        rdir="$(cd "$rdir" 2>/dev/null && pwd)" || {
            echo "${C_RED}Directory not found: $rdir${C_RESET}"
            return 1
        }
    fi

    if [[ ! -d "$rdir/.git" ]]; then
        echo "${C_RED}Not a git repository: $rdir${C_RESET}"
        return 1
    fi

    # Check if already exists
    if [[ -f "$PJ_CONFIG" ]] && grep -q "^$rdir " "$PJ_CONFIG" 2>/dev/null; then
        echo "${C_YELLOW}Already in config: $rdir${C_RESET}"
        return 0
    fi

    # Create config if it doesn't exist
    [[ ! -f "$PJ_CONFIG" ]] && touch "$PJ_CONFIG"

    echo "$rdir = $group" >> "$PJ_CONFIG"
    echo "${C_GREEN}Added:${C_RESET} $(basename "$rdir") ${C_DIM}($group)${C_RESET}"
}

# ── pj remove ─────────────────────────────────────────────────────────────────

cmd_remove() {
    local target="$1"

    if [[ -z "$target" ]]; then
        echo "${C_RED}Usage: pj remove <path|name>${C_RESET}"
        return 1
    fi

    load_config || return 1

    # Try to match by basename first
    local matched_path=""
    local match_count=0

    for i in {1..${#REPO_PATHS[@]}}; do
        if [[ "${REPO_NAMES[$i]}" == "$target" ]] || [[ "${REPO_PATHS[$i]}" == "$target" ]]; then
            matched_path="${REPO_PATHS[$i]}"
            ((match_count++))
        fi
    done

    if [[ $match_count -eq 0 ]]; then
        echo "${C_RED}Not found in config: $target${C_RESET}"
        return 1
    fi

    if [[ $match_count -gt 1 ]]; then
        echo "${C_YELLOW}Ambiguous name '$target'. Multiple matches found:${C_RESET}"
        for i in {1..${#REPO_PATHS[@]}}; do
            [[ "${REPO_NAMES[$i]}" == "$target" ]] && echo "  ${REPO_PATHS[$i]}"
        done
        echo "Please use the full path."
        return 1
    fi

    # Remove the line
    local tmpfile="$(mktemp)"
    grep -v "^${matched_path} " "$PJ_CONFIG" > "$tmpfile"
    mv "$tmpfile" "$PJ_CONFIG"

    echo "${C_GREEN}Removed:${C_RESET} $(basename "$matched_path")"
}

# ── pj init ───────────────────────────────────────────────────────────────────

cmd_init() {
    local root="."
    local force=false
    local dry_run=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --root) root="$2" ; shift ;;
            --force) force=true ;;
            --dry-run) dry_run=true ;;
        esac
        shift
    done

    if [[ -f "$PJ_CONFIG" ]] && ! $force; then
        echo "${C_YELLOW}Config already exists at $PJ_CONFIG${C_RESET}"
        echo "Use ${C_CYAN}pj init --force${C_RESET} to overwrite."
        return 1
    fi

    if [[ ! -d "$root" ]]; then
        echo "${C_RED}Root directory not found: $root${C_RESET}"
        return 1
    fi

    echo "${C_BOLD}Scanning for git repos under ${C_CYAN}$root${C_RESET}${C_BOLD}...${C_RESET}"
    echo ""

    # Discover repos
    local -a found_paths=()
    local -a found_groups=()

    while IFS= read -r gitdir; do
        local repo_path="$(dirname "$gitdir")"

        # Infer group from parent directory name
        local parent_dir="$(basename "$(dirname "$repo_path")")"
        local group="$parent_dir"
        # If repo is directly under root, assign to "default" group
        if [[ "$(dirname "$repo_path")" == "$root" ]]; then
            group="default"
        fi

        found_paths+=("$repo_path")
        found_groups+=("$group")

        local name="$(basename "$repo_path")"
        printf "  ${C_GREEN}Found${C_RESET} %-35s ${C_DIM}(%s)${C_RESET}\n" "$name" "$group"
    done < <(find "$root" -name ".git" -type d -maxdepth 5 2>/dev/null | sort)

    echo ""
    echo " ${C_BOLD}Total: ${#found_paths[@]} repos discovered${C_RESET}"

    if $dry_run; then
        echo ""
        echo " ${C_DIM}(dry run - no config written)${C_RESET}"
        return 0
    fi

    # Write config
    {
        echo "# pj configuration file"
        echo "# Format: /path/to/repo = group-name"
        echo "# Generated on $(date '+%Y-%m-%d %H:%M')"
        echo ""

        # Write entries grouped together
        local -a seen_groups=()
        local -A sg=()
        for i in {1..${#found_paths[@]}}; do
            local g="${found_groups[$i]}"
            if [[ -z "${sg[$g]}" ]]; then
                seen_groups+=("$g")
                sg[$g]=1
            fi
        done
        for group in "${seen_groups[@]}"; do
            echo "# $group"
            for i in {1..${#found_paths[@]}}; do
                if [[ "${found_groups[$i]}" == "$group" ]]; then
                    echo "${found_paths[$i]} = $group"
                fi
            done
            echo ""
        done
    } > "$PJ_CONFIG"

    echo ""
    echo " ${C_GREEN}Config written to ${C_CYAN}$PJ_CONFIG${C_RESET}"
    echo " Edit the file to adjust groups or remove repos."
}

# ── pj sync ───────────────────────────────────────────────────────────────────

cmd_sync() {
    local parallel=false
    local filter_group=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -p|--parallel) parallel=true ;;
            -*) echo "${C_RED}Unknown option: $1${C_RESET}" ; return 1 ;;
            *) filter_group="$1" ;;
        esac
        shift
    done

    load_config || return 1

    local indices=(${(s: :)$(get_filtered_indices "$filter_group")})

    if [[ ${#indices[@]} -eq 0 ]]; then
        if [[ -n "$filter_group" ]]; then
            echo "${C_RED}No repos found in group: $filter_group${C_RESET}"
            echo "Available groups: $(get_unique_groups)"
        else
            echo "${C_RED}No repos configured.${C_RESET}"
        fi
        return 1
    fi

    local label="all repos"
    [[ -n "$filter_group" ]] && label="group '$filter_group'"
    echo ""
    echo " ${C_BOLD}Syncing $label (${#indices[@]} repos)...${C_RESET}"
    print_separator

    local -a ok_repos skipped_repos failed_repos
    local tmpdir="$(mktemp -d)"
    trap "rm -rf '$tmpdir'" EXIT INT TERM

    sync_one_repo() {
        local idx=$1
        local rdir="${REPO_PATHS[$idx]}"
        local name="${REPO_NAMES[$idx]}"
        local outfile="$tmpdir/$name"

        # Check directory exists
        if [[ ! -d "$rdir" ]]; then
            echo "MISSING" > "$outfile"
            return
        fi

        if [[ ! -d "$rdir/.git" ]]; then
            echo "NOT_GIT" > "$outfile"
            return
        fi

        # Check for uncommitted changes
        local status_output
        status_output=$(git -C "$rdir" status --porcelain 2>&1)
        if [[ -n "$status_output" ]]; then
            echo "DIRTY" > "$outfile"
            return
        fi

        # Detect default branch
        local default_branch
        default_branch=$(get_default_branch "$rdir")
        if [[ -z "$default_branch" ]]; then
            echo "NO_DEFAULT" > "$outfile"
            return
        fi

        # Checkout default branch
        local checkout_out
        checkout_out=$(git -C "$rdir" checkout "$default_branch" 2>&1)
        if [[ $? -ne 0 ]]; then
            echo "CHECKOUT_FAIL:$checkout_out" > "$outfile"
            return
        fi

        # Pull latest (fallback to explicit origin/<branch> if no upstream)
        local pull_out
        pull_out=$(git -C "$rdir" pull --ff-only 2>&1)
        if [[ $? -ne 0 ]]; then
            # Retry with explicit remote/branch if no upstream tracking
            if [[ "$pull_out" == *"no tracking information"* ]] || [[ "$pull_out" == *"There is no tracking"* ]]; then
                git -C "$rdir" branch --set-upstream-to="origin/$default_branch" "$default_branch" 2>/dev/null
                pull_out=$(git -C "$rdir" pull --ff-only 2>&1)
                if [[ $? -ne 0 ]]; then
                    echo "PULL_FAIL:$pull_out" > "$outfile"
                    return
                fi
            else
                echo "PULL_FAIL:$pull_out" > "$outfile"
                return
            fi
        fi

        echo "OK:$default_branch:$pull_out" > "$outfile"
    }

    local name="" result="" branch="" detail=""

    if $parallel; then
        # Parallel execution with concurrency limit
        local max_jobs=4
        local running=0
        local -a pids=()
        local pid=""
        for idx in "${indices[@]}"; do
            sync_one_repo "$idx" &
            pids+=($!)
            ((running++))
            if [[ $running -ge $max_jobs ]]; then
                # Wait for any one job to finish before starting the next
                wait "${pids[1]}" 2>/dev/null
                pids=("${pids[@]:1}")
                ((running--))
            fi
        done
        # Wait for remaining jobs
        for pid in "${pids[@]}"; do
            wait "$pid" 2>/dev/null
        done
    else
        # Sequential execution
        for idx in "${indices[@]}"; do
            name="${REPO_NAMES[$idx]}"
            printf "  ${C_CYAN}%-30s${C_RESET} " "$name"
            sync_one_repo "$idx"

            result="$(cat "$tmpdir/$name" 2>/dev/null)"
            case "$result" in
                OK:*)
                    branch="${${result#OK:}%%:*}"
                    detail="${result#OK:*:}"
                    if [[ "$detail" == *"Already up to date"* ]]; then
                        printf "${C_GREEN}OK${C_RESET} ${C_DIM}($branch, up to date)${C_RESET}\n"
                    else
                        printf "${C_BOLD_GREEN}UPDATED${C_RESET} ${C_DIM}($branch)${C_RESET}\n"
                    fi
                    ok_repos+=("$name")
                    ;;
                DIRTY)
                    printf "${C_YELLOW}SKIPPED${C_RESET} ${C_DIM}(uncommitted changes)${C_RESET}\n"
                    skipped_repos+=("$name")
                    ;;
                MISSING)
                    printf "${C_RED}MISSING${C_RESET} ${C_DIM}(directory not found)${C_RESET}\n"
                    failed_repos+=("$name")
                    ;;
                NOT_GIT)
                    printf "${C_RED}ERROR${C_RESET} ${C_DIM}(not a git repo)${C_RESET}\n"
                    failed_repos+=("$name")
                    ;;
                NO_DEFAULT)
                    printf "${C_RED}ERROR${C_RESET} ${C_DIM}(cannot detect default branch)${C_RESET}\n"
                    failed_repos+=("$name")
                    ;;
                CHECKOUT_FAIL:*)
                    printf "${C_RED}FAILED${C_RESET} ${C_DIM}(checkout: ${result#CHECKOUT_FAIL:})${C_RESET}\n"
                    failed_repos+=("$name")
                    ;;
                PULL_FAIL:*)
                    printf "${C_RED}FAILED${C_RESET} ${C_DIM}(pull: ${result#PULL_FAIL:})${C_RESET}\n"
                    failed_repos+=("$name")
                    ;;
                *)
                    printf "${C_RED}UNKNOWN${C_RESET}\n"
                    failed_repos+=("$name")
                    ;;
            esac
        done
    fi

    # For parallel mode, display results after all complete
    if $parallel; then
        for idx in "${indices[@]}"; do
            name="${REPO_NAMES[$idx]}"
            printf "  ${C_CYAN}%-30s${C_RESET} " "$name"

            result="$(cat "$tmpdir/$name" 2>/dev/null)"
            case "$result" in
                OK:*)
                    branch="${${result#OK:}%%:*}"
                    detail="${result#OK:*:}"
                    if [[ "$detail" == *"Already up to date"* ]]; then
                        printf "${C_GREEN}OK${C_RESET} ${C_DIM}($branch, up to date)${C_RESET}\n"
                    else
                        printf "${C_BOLD_GREEN}UPDATED${C_RESET} ${C_DIM}($branch)${C_RESET}\n"
                    fi
                    ok_repos+=("$name")
                    ;;
                DIRTY)
                    printf "${C_YELLOW}SKIPPED${C_RESET} ${C_DIM}(uncommitted changes)${C_RESET}\n"
                    skipped_repos+=("$name")
                    ;;
                MISSING)
                    printf "${C_RED}MISSING${C_RESET} ${C_DIM}(directory not found)${C_RESET}\n"
                    failed_repos+=("$name")
                    ;;
                NOT_GIT)
                    printf "${C_RED}ERROR${C_RESET} ${C_DIM}(not a git repo)${C_RESET}\n"
                    failed_repos+=("$name")
                    ;;
                NO_DEFAULT)
                    printf "${C_RED}ERROR${C_RESET} ${C_DIM}(cannot detect default branch)${C_RESET}\n"
                    failed_repos+=("$name")
                    ;;
                CHECKOUT_FAIL:*)
                    printf "${C_RED}FAILED${C_RESET} ${C_DIM}(checkout: ${result#CHECKOUT_FAIL:})${C_RESET}\n"
                    failed_repos+=("$name")
                    ;;
                PULL_FAIL:*)
                    printf "${C_RED}FAILED${C_RESET} ${C_DIM}(pull: ${result#PULL_FAIL:})${C_RESET}\n"
                    failed_repos+=("$name")
                    ;;
                *)
                    printf "${C_RED}FAILED${C_RESET} ${C_DIM}(${result:-no output})${C_RESET}\n"
                    failed_repos+=("$name")
                    ;;
            esac
        done
    fi

    # Summary
    echo ""
    print_separator
    echo ""
    [[ ${#ok_repos[@]} -gt 0 ]] && printf " ${C_GREEN}SUCCESS${C_RESET} (%d): %s\n" "${#ok_repos[@]}" "${(j:, :)ok_repos}"
    [[ ${#skipped_repos[@]} -gt 0 ]] && printf " ${C_YELLOW}SKIPPED${C_RESET} (%d): %s\n" "${#skipped_repos[@]}" "${(j:, :)skipped_repos}"
    [[ ${#failed_repos[@]} -gt 0 ]] && printf " ${C_RED}FAILED${C_RESET}  (%d): %s\n" "${#failed_repos[@]}" "${(j:, :)failed_repos}"
    echo ""
}

# ── pj status ─────────────────────────────────────────────────────────────────

cmd_status() {
    local filter_group="$1"

    load_config || return 1

    local indices=(${(s: :)$(get_filtered_indices "$filter_group")})

    if [[ ${#indices[@]} -eq 0 ]]; then
        echo "${C_RED}No repos found.${C_RESET}"
        return 1
    fi

    echo ""
    printf " ${C_BOLD}%-28s %-25s %-10s %s${C_RESET}\n" "REPO" "BRANCH" "STATUS" "AHEAD/BEHIND"
    print_separator

    local current_group="" rdir="" name="" group=""
    local branch="" default_branch="" branch_colored=""
    local status_text="" status_colored="" porcelain="" changed=""
    local ahead=0 behind=0 ab_text="" counts="" ab_colored="" pad=0

    for idx in "${indices[@]}"; do
        rdir="${REPO_PATHS[$idx]}"
        name="${REPO_NAMES[$idx]}"
        group="${REPO_GROUPS[$idx]}"

        # Print group header
        if [[ "$group" != "$current_group" ]]; then
            [[ -n "$current_group" ]] && echo ""
            printf " ${C_BOLD_WHITE}%s${C_RESET}\n" "$group"
            current_group="$group"
        fi

        # Check if repo exists
        if [[ ! -d "$rdir/.git" ]]; then
            printf "   ${C_RED}%-25s %-25s %-10s${C_RESET}\n" "$name" "-" "[MISSING]"
            continue
        fi

        # Get branch
        branch=$(git -C "$rdir" branch --show-current 2>/dev/null)
        [[ -z "$branch" ]] && branch="(detached)"

        # Get default branch for color coding
        default_branch=$(get_default_branch "$rdir")

        # Color the branch name
        if [[ "$branch" == "$default_branch" ]]; then
            branch_colored="${C_GREEN}${branch}${C_RESET}"
        else
            branch_colored="${C_YELLOW}${branch}${C_RESET}"
        fi

        # Check dirty/clean
        porcelain=$(git -C "$rdir" status --porcelain 2>/dev/null)
        if [[ -n "$porcelain" ]]; then
            changed=$(echo "$porcelain" | wc -l | tr -d ' ')
            status_text="DIRTY($changed)"
            status_colored="${C_RED}${status_text}${C_RESET}"
        else
            status_text="CLEAN"
            status_colored="${C_GREEN}${status_text}${C_RESET}"
        fi

        # Ahead/behind
        ahead=0 behind=0
        counts=$(git -C "$rdir" rev-list --left-right --count HEAD...@{upstream} 2>/dev/null)
        if [[ $? -eq 0 ]] && [[ -n "$counts" ]]; then
            ahead=$(echo "$counts" | awk '{print $1}')
            behind=$(echo "$counts" | awk '{print $2}')
        fi

        ab_colored=""
        if [[ $ahead -gt 0 ]]; then
            ab_colored="${C_YELLOW}↑${ahead}${C_RESET}"
        else
            ab_colored="${C_DIM}↑0${C_RESET}"
        fi
        ab_colored+=" "
        if [[ $behind -gt 0 ]]; then
            ab_colored+="${C_RED}↓${behind}${C_RESET}"
        else
            ab_colored+="${C_DIM}↓0${C_RESET}"
        fi

        # Print row - use fixed width for the raw text, then apply color
        printf "   ${C_CYAN}%-25s${C_RESET} " "$name"
        printf "%-25s " "$branch_colored"

        # Pad status based on raw text length
        pad=$((10 - ${#status_text}))
        printf "%s%*s" "$status_colored" "$pad" ""
        printf " %s\n" "$ab_colored"
    done

    echo ""
}

# ── pj branches ───────────────────────────────────────────────────────────────

cmd_branches() {
    local filter=""
    local show_local=true show_remote=true

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --local) show_remote=false ;;
            --remote) show_local=false ;;
            -*) echo "${C_RED}Unknown option: $1${C_RESET}" ; return 1 ;;
            *) filter="$1" ;;
        esac
        shift
    done

    load_config || return 1

    local rdir="" name="" group="" current_branch="" branch="" display=""
    echo ""

    for i in {1..${#REPO_PATHS[@]}}; do
        rdir="${REPO_PATHS[$i]}"
        name="${REPO_NAMES[$i]}"
        group="${REPO_GROUPS[$i]}"

        # Apply filter: match by repo name or group name
        if [[ -n "$filter" ]]; then
            if [[ "$name" != *"$filter"* ]] && [[ "$group" != "$filter" ]]; then
                continue
            fi
        fi

        if [[ ! -d "$rdir/.git" ]]; then
            printf " ${C_RED}%s [MISSING]${C_RESET}\n\n" "$name"
            continue
        fi

        printf " ${C_BOLD_WHITE}%s${C_RESET} ${C_DIM}(%s)${C_RESET}\n" "$name" "$group"

        current_branch=$(git -C "$rdir" branch --show-current 2>/dev/null)

        # Local branches
        if $show_local; then
            while IFS= read -r branch; do
                branch="${branch#"${branch%%[! ]*}"}"
                if [[ "$branch" == \** ]]; then
                    branch="${branch#\* }"
                    printf "   ${C_BOLD_GREEN}* %s${C_RESET}\n" "$branch"
                else
                    printf "   ${C_CYAN}  %s${C_RESET}\n" "$branch"
                fi
            done < <(git -C "$rdir" branch 2>/dev/null)
        fi

        # Remote branches
        if $show_remote; then
            while IFS= read -r branch; do
                branch="${branch#"${branch%%[! ]*}"}"
                [[ -z "$branch" ]] && continue
                # Skip HEAD pointer
                [[ "$branch" == *"HEAD"* ]] && continue
                # Remove remotes/ prefix for display
                display="${branch#remotes/}"
                printf "   ${C_DIM}  %s${C_RESET}\n" "$display"
            done < <(git -C "$rdir" branch -r 2>/dev/null)
        fi

        echo ""
    done
}

# ── pj cleanup ────────────────────────────────────────────────────────────────

cmd_cleanup() {
    local filter_group=""
    local dry_run=false
    local force=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run|-n) dry_run=true ;;
            --force|-f) force=true ;;
            -*) echo "${C_RED}Unknown option: $1${C_RESET}" ; return 1 ;;
            *) filter_group="$1" ;;
        esac
        shift
    done

    load_config || return 1

    local indices=(${(s: :)$(get_filtered_indices "$filter_group")})
    local total_branches=0
    local total_repos=0

    # Protected branch patterns
    local -a protected=(develop staging release hotfix)

    echo ""
    echo " ${C_BOLD}Scanning for merged branches...${C_RESET}"
    echo ""

    local -A repo_branches  # repo_name -> branch list
    local rdir="" name="" default_branch="" current_branch="" branch=""
    local is_protected=false
    local -a to_delete=()

    for idx in "${indices[@]}"; do
        rdir="${REPO_PATHS[$idx]}"
        name="${REPO_NAMES[$idx]}"

        [[ ! -d "$rdir/.git" ]] && continue

        default_branch=$(get_default_branch "$rdir")
        [[ -z "$default_branch" ]] && continue

        current_branch=$(git -C "$rdir" branch --show-current 2>/dev/null)

        # Get merged branches
        to_delete=()
        while IFS= read -r branch; do
            branch="${branch#"${branch%%[! ]*}"}"
            branch="${branch#\* }"

            # Skip default branch and current branch
            [[ "$branch" == "$default_branch" ]] && continue
            [[ "$branch" == "$current_branch" ]] && continue
            [[ -z "$branch" ]] && continue

            # Skip protected patterns
            is_protected=false
            for p in "${protected[@]}"; do
                [[ "$branch" == "$p" || "$branch" == "$p"/* ]] && is_protected=true
            done
            $is_protected && continue

            to_delete+=("$branch")
        done < <(git -C "$rdir" branch --merged "$default_branch" 2>/dev/null)

        if [[ ${#to_delete[@]} -gt 0 ]]; then
            printf " ${C_BOLD_WHITE}%s${C_RESET} ${C_DIM}(%s → %s)${C_RESET}\n" "$name" "${#to_delete[@]} branches" "$default_branch"
            for branch in "${to_delete[@]}"; do
                printf "   ${C_YELLOW}%s${C_RESET}\n" "$branch"
            done
            echo ""

            repo_branches[$name]="${(j:|:)to_delete}"
            ((total_branches += ${#to_delete[@]}))
            ((total_repos++))
        fi
    done

    if [[ $total_branches -eq 0 ]]; then
        echo " ${C_GREEN}No merged branches to clean up.${C_RESET}"
        echo ""
        return 0
    fi

    print_separator
    printf " ${C_BOLD}Total: %d branches across %d repos${C_RESET}\n" "$total_branches" "$total_repos"
    echo ""

    if $dry_run; then
        echo " ${C_DIM}(dry run - no branches deleted)${C_RESET}"
        echo ""
        return 0
    fi

    # Confirm
    if ! $force; then
        printf " Delete these branches? [y/N]: "
        read -r confirm
        if [[ "$confirm" != [yY] ]]; then
            echo " ${C_DIM}Cancelled.${C_RESET}"
            echo ""
            return 0
        fi
    fi

    echo ""

    # Execute deletion
    local deleted=0 errors=0 out=""
    local -a del_branches=()
    for idx in "${indices[@]}"; do
        rdir="${REPO_PATHS[$idx]}"
        name="${REPO_NAMES[$idx]}"

        [[ -z "${repo_branches[$name]}" ]] && continue

        del_branches=(${(s:|:)repo_branches[$name]})
        for branch in "${del_branches[@]}"; do
            out=$(git -C "$rdir" branch -d "$branch" 2>&1)
            if [[ $? -eq 0 ]]; then
                printf "  ${C_GREEN}Deleted${C_RESET} %s/%s\n" "$name" "$branch"
                ((deleted++))
            else
                printf "  ${C_RED}Failed${C_RESET}  %s/%s: %s\n" "$name" "$branch" "$out"
                ((errors++))
            fi
        done
    done

    echo ""
    print_separator
    printf " ${C_GREEN}Deleted: %d${C_RESET}" "$deleted"
    [[ $errors -gt 0 ]] && printf "  ${C_RED}Errors: %d${C_RESET}" "$errors"
    echo ""
    echo ""
}

# ── Main Dispatch ─────────────────────────────────────────────────────────────

main() {
    local cmd="${1:-help}"
    shift 2>/dev/null

    case "$cmd" in
        sync)     cmd_sync "$@" ;;
        status|st) cmd_status "$@" ;;
        branches|br) cmd_branches "$@" ;;
        cleanup)  cmd_cleanup "$@" ;;
        list|ls)  cmd_list "$@" ;;
        add)      cmd_add "$@" ;;
        remove|rm) cmd_remove "$@" ;;
        init)     cmd_init "$@" ;;
        help|-h|--help) cmd_help ;;
        version|-v|--version) echo "pj v${PJ_VERSION}" ;;
        *)
            echo "${C_RED}Unknown command: $cmd${C_RESET}"
            echo "Run '${C_CYAN}pj help${C_RESET}' for usage."
            return 1
            ;;
    esac
}

main "$@"
